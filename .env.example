# Local dev: a plain SQLite file, no external account needed.
DATABASE_URL="file:./dev.db"

# Production (e.g. Vercel): point these at a Turso database instead —
# Vercel's serverless functions don't have a persistent local disk, so the
# file: URL above only works for local development.
# DATABASE_URL="libsql://<your-db>-<org>.turso.io"
# TURSO_AUTH_TOKEN="..."

# Optional: also post queue-call notifications to a Slack incoming webhook.
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."
